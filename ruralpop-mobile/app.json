{
  "expo": {
    "name": "Ruralpop",
    "slug": "ruralpop-mobile",
    "scheme": "ruralpop",
    "version": "1.0.11",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D2422"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ruralpop.ruralpopapp",
      "buildNumber": "33",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "es",
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#059669"
      },
      "package": "com.ruralpop.app",
      "versionCode": 33,
      "permissions": [
        "com.google.android.gms.permission.AD_ID",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "ndkVersion": "27.1.12297006",
            "useLegacyPackaging": true
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2042067618462129~3393473801",
          "iosAppId": "ca-app-pub-2042067618462129~3393473801"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.ruralpop.ruralpopapp",
          "enableGooglePay": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0db84bcc-5fb6-4cf2-9e28-525900e9a799"
      }
    },
    "owner": "ruralpop",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0db84bcc-5fb6-4cf2-9e28-525900e9a799"
    }
  }
}
