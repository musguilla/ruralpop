{
  "expo": {
    "name": "Ruralpop",
    "slug": "ruralpop-mobile",
    "scheme": "ruralpop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D2422"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ruralpop.ruralpopapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D2422"
      },
      "package": "com.ruralpop.ruralpopapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0db84bcc-5fb6-4cf2-9e28-525900e9a799"
      }
    },
    "owner": "ruralpop"
  }
}